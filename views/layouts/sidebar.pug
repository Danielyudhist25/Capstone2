aside.main-sidebar.sidebar-dark-primary.elevation-4

    a.brand-link(href="/dashboard")

        img.brand-image.img-circle.elevation-3(
            src="https://adminlte.io/themes/v3/dist/img/AdminLTELogo.png"
            alt="Logo"
        )

        span.brand-text.font-weight-light Inventaris Lab

    .sidebar

        .user-panel.mt-3.pb-3.mb-3.d-flex

            .image
                img.img-circle.elevation-2(
                    src="https://adminlte.io/themes/v3/dist/img/user2-160x160.jpg"
                )

            .info
                a.d-block(href="#")
                    = user ? user.nama : 'Guest'

        nav.mt-2

            ul.nav.nav-pills.nav-sidebar.flex-column(
                data-widget="treeview"
                role="menu"
                data-accordion="false"
            )

                li.nav-item
                    a.nav-link(href="/dashboard")
                        i.nav-icon.fas.fa-tachometer-alt
                        p Dashboard

                li.nav-header MASTER DATA

                li.nav-item
                    a.nav-link(href="/users")
                        i.nav-icon.fas.fa-users
                        p Users

                li.nav-item
                    a.nav-link(href="/rooms")
                        i.nav-icon.fas.fa-door-open
                        p Rooms

                li.nav-header PENGADAAN

                li.nav-item
                    a.nav-link(href="/drafts")
                        i.nav-icon.fas.fa-file-alt
                        p Draft Pengadaan

                li.nav-header INVENTARIS

                li.nav-item
                    a.nav-link(href="/inventories")
                        i.nav-icon.fas.fa-boxes
                        p Inventaris

                li.nav-item
                    a.nav-link(href="/consumables")
                        i.nav-icon.fas.fa-box-open
                        p Barang Habis Pakai

                li.nav-item
                    a.nav-link(href="/maintenance")
                        i.nav-icon.fas.fa-tools
                        p Maintenance